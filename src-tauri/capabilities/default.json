{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all app windows",
  "windows": ["pet", "panel", "settings"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "store:allow-delete",
    "store:allow-keys",
    "store:allow-values",
    "store:allow-entries",
    "store:allow-length",
    "store:allow-has",
    "store:allow-clear",
    "store:allow-reload",
    "dialog:default",
    "dialog:allow-open"
  ]
}
